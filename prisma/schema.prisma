// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?

  accounts      Account[]
  sessions      Session[]
  commitments   Commitment[]
  scannedEmails ScannedEmail[]
  scratchpad    ScratchpadEntry?
}

model Account {
  id                       String  @id @default(cuid())
  userId                   String
  type                     String
  provider                 String
  providerAccountId        String
  refresh_token            String?
  access_token             String?
  expires_at               Int?
  token_type               String?
  scope                    String?
  id_token                 String?
  session_state            String?
  refresh_token_expires_in Int?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum CommitmentDirection {
  OWED_TO_YOU
  OWED_BY_YOU
}

enum CommitmentStatus {
  OPEN
  DONE
  SNOOZED
}

// Urgency bucket, independent of direction. Direction (owed to/by you)
// drives which ledger column a row sits in; priority drives how it's
// flagged within that column.
enum CommitmentPriority {
  HIGH_PRIORITY
  REPLY_DEBT
  QUICK_WIN
}

model Commitment {
  id                    String              @id @default(cuid())
  userId                String
  direction             CommitmentDirection
  priority              CommitmentPriority  @default(QUICK_WIN)
  counterparty          String
  description           String
  contextSummary        String?
  dueDate               DateTime?
  status                CommitmentStatus    @default(OPEN)
  confidence            Float
  sourceGmailMessageId  String?
  sourceThreadId        String?
  sourceSnippet         String?
  readyToClose          Boolean             @default(false)
  closeSuggestionReason String?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
}

model ScratchpadEntry {
  id        String   @id @default(cuid())
  userId    String   @unique
  content   String   @default("")
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ScannedEmail {
  id              String   @id @default(cuid())
  userId          String
  gmailMessageId  String
  scannedAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, gmailMessageId])
}
