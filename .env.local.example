# Copy this file to .env.local and fill in the values below.

# --- Database ---
# Placeholder only — the real path is resolved from process.cwd() in
# lib/prisma.ts (runtime) and prisma.config.ts (CLI).
DATABASE_URL="file:./prisma/dev.db"

# --- Google OAuth (Google Cloud Console) ---
# 1. Go to https://console.cloud.google.com/ and create (or select) a project.
# 2. APIs & Services > Library: enable the "Gmail API".
# 3. APIs & Services > OAuth consent screen: set up an External consent screen
#    (Testing mode is fine), add your own Google account as a test user, and
#    add the scope https://www.googleapis.com/auth/gmail.readonly.
# 4. APIs & Services > Credentials > Create Credentials > OAuth client ID:
#      - Application type: Web application
#      - Authorized redirect URI: http://localhost:3000/api/auth/callback/google
# 5. Copy the generated Client ID and Client Secret below.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Auth.js / NextAuth v5 ---
# Generate a secret with: npx auth secret
AUTH_SECRET=
AUTH_URL=http://localhost:3000

# --- Anthropic (Claude API) ---
# Get a key from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
# Optional: override the extraction model (defaults to claude-sonnet-5)
ANTHROPIC_MODEL=claude-sonnet-5
# Set DEBUG_EXTRACT=1 to log raw Claude tool-use output per email (lib/extract.ts)
